# OpenRouter (recommended - single key for both large & small models)
OPENROUTER_API_KEY=

# Default model slugs (override with --large / --small CLI flags)
ISOMODEL_LARGE=anthropic/claude-3.5-sonnet
ISOMODEL_SMALL=mistralai/mistral-7b-instruct

# Optional: alternative provider (raw OpenAI-compatible endpoint)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
